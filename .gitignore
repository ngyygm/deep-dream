# 排除 docs、graph、data 目录（含书籍等本地数据）
docs/
graph/
data/

# 本地配置（含路径、API 等），不提交；仅提交 service_config.example.json
service_config.json
*.local.json
# 冒烟测试本地配置，不提交
service_config.smoke.json
*.smoke.json
.env
.env.*

# 排除 Python 缓存文件
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 虚拟环境
.venv/
venv/
env/

# 测试与类型检查缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# 打包
*.egg-info/
dist/
build/

# 流水线蒸馏输出（与 service_config.pipeline.distill_data_dir 默认一致）
distill_pipeline/

# 日志与系统文件
*.log
.DS_Store
