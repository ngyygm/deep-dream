{
  "host": "0.0.0.0",
  "port": 16200,
  "auto_port_fallback": false,
  "log_mode": "detail",
  "monitor_refresh_seconds": 1.0,
  "storage_path": "./graph",
  "storage": {
    "backend": "sqlite",
    "_comment_backend": "sqlite | neo4j",
    "neo4j": {
      "uri": "bolt://localhost:7687",
      "user": "neo4j",
      "password": "tmg2024secure"
    },
    "vector_dim": 1024
  },
  "llm": {
    "api_key": "ollama",
    "model": "model_name",
    "base_url": "http://127.0.0.1:11434",
    "think": false,
    "max_tokens": 3000,
    "context_window_tokens": 8000,
    "max_concurrency": 3,
    "alignment": {
      "enabled": true,
      "max_concurrency": 2,
      "api_key": "ollama",
      "model": "alignment_model_name",
      "base_url": "http://127.0.0.1:11435",
      "think": false,
      "max_tokens": 8192
    },
    "dream": {
      "enabled": false,
      "api_key": "ollama",
      "model": "dream_model_name",
      "base_url": "http://127.0.0.1:11434",
      "think": false,
      "max_tokens": 4096
    }
  },
  "embedding": {
    "model": "Qwen/Qwen3-Embedding-0.6B",
    "device": "cpu"
  },
  "chunking": {
    "window_size": 1000,
    "overlap": 200
  },
  "runtime": {
    "concurrency": {
      "queue_workers": 1,
      "window_workers": 1
    },
    "task": {
      "load_cache_memory": false
    },
    "retry": {
      "queue_max_retries": 2,
      "queue_retry_delay_seconds": 2
    }
  },
  "pipeline": {
    "search": {
      "similarity_threshold": 0.7,
      "max_similar_entities": 10,
      "content_snippet_length": 50,
      "relation_content_snippet_length": 50
    },
    "alignment": {
      "max_alignment_candidates": null
    },
    "extraction": {
      "extraction_rounds": 1,
      "entity_extraction_rounds": 1,
      "relation_extraction_rounds": 1,
      "entity_post_enhancement": false,
      "prompt_memory_cache_max_chars": 2000,
      "compress_multi_round_extraction": false
    },
    "remember": {
      "mode": "multi_step",
      "anchor_recall_rounds": 1,
      "named_entity_recall_rounds": 1,
      "abstract_recall_rounds": 1,
      "coverage_gap_rounds": 1,
      "entity_write_batch_size": 6,
      "relation_hint_rounds": 1,
      "relation_expand_rounds": 1,
      "relation_write_rounds": 1,
      "pre_alignment_validation_retries": 2,
      "min_relation_candidates_per_window": 0,
      "min_entities_per_100_chars_soft_target": 0.0,
      "alignment_policy": "conservative"
    },
    "debug": {
      "distill_data_dir": "distill_pipeline"
    }
  },
  "flask_threaded": true
}
