{
  "host": "0.0.0.0",
  "port": 16200,
  "auto_port_fallback": false,
  "log_mode": "detail",
  "monitor_refresh_seconds": 1.0,
  "storage_path": "./graph",
  "llm": {
    "api_key": "ollama",
    "model": "model_name",
    "base_url": "http://127.0.0.1:11434",
    "think": false,
    "max_tokens": 16384,
    "max_concurrency": 3
  },
  "embedding": {
    "model": "Qwen/Qwen3-Embedding-0.6B",
    "device": "cpu"
  },
  "chunking": {
    "window_size": 1000,
    "overlap": 200
  },
  "runtime": {
    "concurrency": {
      "queue_workers": 1,
      "max_total_workers": 1
    },
    "retry": {
      "queue_max_retries": 2,
      "queue_retry_delay_seconds": 2
    }
  },
  "pipeline": {
    "max_concurrent_windows": 1,
    "similarity_threshold": 0.7,
    "max_similar_entities": 10,
    "content_snippet_length": 50,
    "relation_content_snippet_length": 50,
    "entity_extraction_rounds": 1,
    "relation_extraction_rounds": 1,
    "extraction_rounds": 1,
    "entity_post_enhancement": false,
    "load_cache_memory": false,
    "max_alignment_candidates": null,
    "distill_data_dir": "distill_pipeline"
  },
  "flask_threaded": true
}
