#!/usr/bin/env bash
# dream-code — Deep Dream 知识图谱增强版 AI 助手
# 基于 Claude Code，预配置 Deep Dream MCP 服务器
#
# 用法: dream-code [claude-code 参数...]
# 环境变量:
#   DREAM_CODE_CONFIG_DIR  覆盖配置目录（默认 ~/.dream-code）
#   DREAM_CODE_SKIP_CHECK  设为 1 跳过服务健康检查

set -euo pipefail

# ── 配置目录 ──────────────────────────────────────────────
DREAM_HOME="${DREAM_CODE_CONFIG_DIR:-$HOME/.dream-code}"
export CLAUDE_CONFIG_DIR="$DREAM_HOME"

# ── 项目根目录（Deep Dream 仓库） ─────────────────────────
# 尝试从脚本位置推导，回退到当前目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# ── 首次运行初始化 ─────────────────────────────────────────
_init_if_needed() {
    if [ -f "$DREAM_HOME/settings.json" ]; then
        return
    fi

    echo ">>> Initializing dream-code config..."
    mkdir -p "$DREAM_HOME"/{skills,projects,sessions,memory,plans,tasks,mcp-servers}

    # 写入默认配置（含 Deep Dream MCP server）
    cat > "$DREAM_HOME/settings.json" << 'SETTINGS_EOF'
{
  "mcpServers": {
    "deep-dream": {
      "command": "/home/linkco/anaconda3/bin/python3",
      "args": ["server/mcp/deep_dream_server.py"],
      "cwd": "/home/linkco/exa/Deep-Dream",
      "env": {
        "DEEP_DREAM_BASE_URL": "http://localhost:16200",
        "DEEP_DREAM_GRAPH_ID": "default"
      }
    }
  }
}
SETTINGS_EOF

    echo "    Config written to $DREAM_HOME/settings.json"

    # 安装 skill 文件
    _install_skills
}

# ── 安装 Skills ────────────────────────────────────────────
_install_skills() {
    local src="$PROJECT_ROOT/src/dream_code/skills"
    local dst="$DREAM_HOME/skills"

    if [ ! -d "$src" ]; then
        return
    fi

    echo "    Installing skills..."

    # deep-dream skill
    if [ -d "$src/deep-dream" ]; then
        mkdir -p "$dst/deep-dream"
        cp -r "$src/deep-dream"/* "$dst/deep-dream/"
    fi

    # dream skill (含 types/)
    if [ -d "$src/dream" ]; then
        mkdir -p "$dst/dream/types"
        cp -r "$src/dream"/* "$dst/dream/"
    fi
}

# ── Deep Dream 服务健康检查 ───────────────────────────────
_check_api_health() {
    if [ "${DREAM_CODE_SKIP_CHECK:-0}" = "1" ]; then
        return 0
    fi

    if curl -sf "http://localhost:16200/api/v1/health" > /dev/null 2>&1; then
        return 0
    fi

    echo ">>> Deep Dream API server is not running."
    echo "    Starting services..."

    # 尝试通过 Python CLI 启动服务
    if command -v dream-code-python &>/dev/null; then
        dream-code-python start 2>/dev/null || true
    elif [ -f "$PROJECT_ROOT/src/dream_code/cli.py" ]; then
        (cd "$PROJECT_ROOT" && python -m dream_code.cli start 2>/dev/null) || true
    fi

    # 等待服务启动
    local retries=30
    while [ $retries -gt 0 ]; do
        if curl -sf "http://localhost:16200/api/v1/health" > /dev/null 2>&1; then
            echo "    Deep Dream API is ready."
            return 0
        fi
        sleep 1
        retries=$((retries - 1))
    done

    echo "    [Warning] Deep Dream API did not start. KG tools will be unavailable."
    return 1
}

# ── 主流程 ────────────────────────────────────────────────
_init_if_needed
_check_api_health

# ── 检查 claude 二进制 ────────────────────────────────────
if ! command -v claude &>/dev/null; then
    echo "Error: 'claude' binary not found in PATH."
    echo "Please install Claude Code first: https://docs.anthropic.com/en/docs/claude-code"
    exit 1
fi

# ── 启动 Claude Code ──────────────────────────────────────
exec claude "$@"
